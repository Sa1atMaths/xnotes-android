<?xml version="1.0" encoding="utf-8"?>
<!--
  XNotes loading animation — frame-by-frame AnimationDrawable.
  24 frames @ ~67ms = ~1.6s loop.
  Place this file in res/drawable/ and the PNG frames in res/drawable-nodpi/.
-->
